#### Example: Request all parameters from the vehicle
curl -X POST http://0.0.0.0:8088/v1/mavlink \
  -H "Content-Type: application/json" \
  -d '{
    "header": {
      "system_id": 255,
      "component_id": 0,
      "sequence": 0
    },
    "message": {
      "type": "PARAM_REQUEST_LIST",
      "target_system": 1,
      "target_component": 1
    }
  }'

